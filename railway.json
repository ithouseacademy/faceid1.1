{
  "deploy": {
    "numReplicas": 1,
    "startCommand": "gunicorn employee_face_recognition.wsgi --bind 0.0.0.0:$PORT",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "cron": [
    {
      "command": "python manage.py cleanup_old_data",
      "schedule": "0 0 1 */2 *"
    }
  ]
}